From 323784fb707af5c4afa4150abcbe19d24de1768d Mon Sep 17 00:00:00 2001
From: ttyS3 <ttys3.rust@gmail.com>
Date: Sun, 26 Apr 2026 14:22:28 +0000
Subject: [PATCH] feat(dll): UCM_EXTRACTFILE explicit id 100 + OK/ERR progress
 callbacks

---
 dll.cpp | 49 ++++++++++++++++++++++++++++++++++++++++++++++++-
 dll.hpp |  8 +++++++-
 2 files changed, 55 insertions(+), 2 deletions(-)

diff --git a/dll.cpp b/dll.cpp
index c787013..f0a69bf 100644
--- a/dll.cpp
+++ b/dll.cpp
@@ -538,8 +538,55 @@ int PASCAL RARExtractAllW(HANDLE hArcData,wchar *DestPath)
     {
       size_t Size=Data->Arc.ReadHeader();
       
+      // Check if this is a file header and notify callback
+      bool IsFileHeader = (Data->Arc.GetHeaderType()==HEAD_FILE);
+      std::wstring CurrentFileName;
+      int64 CurrentFileSize = 0;
+      
+      if (IsFileHeader)
+      {
+        CurrentFileName = Data->Arc.FileHead.FileName;
+        CurrentFileSize = Data->Arc.FileHead.UnpSize;
+        
+        // Notify callback that file extraction is starting
+        if (Data->Cmd.Callback!=NULL)
+        {
+          if (Data->Cmd.Callback(UCM_EXTRACTFILE, Data->Cmd.UserData,
+              (LPARAM)CurrentFileName.c_str(), (LPARAM)CurrentFileSize)==-1)
+          {
+            return ERAR_SUCCESS; // User cancelled extraction
+          }
+        }
+      }
+      
       bool Repeat=false;
-      if (!Data->Extract.ExtractCurrentFile(Data->Arc,Size,Repeat))
+      bool Success = Data->Extract.ExtractCurrentFile(Data->Arc,Size,Repeat);
+      
+      // Notify callback of extraction result. Returning -1 from either
+      // UCM_EXTRACTFILE_OK or UCM_EXTRACTFILE_ERR aborts extraction in
+      // the same way UCM_EXTRACTFILE does, so cancel semantics are
+      // uniform across all three events.
+      if (IsFileHeader && Data->Cmd.Callback!=NULL)
+      {
+        if (Success)
+        {
+          if (Data->Cmd.Callback(UCM_EXTRACTFILE_OK, Data->Cmd.UserData,
+              (LPARAM)CurrentFileName.c_str(), 0)==-1)
+          {
+            return ERAR_SUCCESS; // User cancelled extraction
+          }
+        }
+        else if (!Repeat)
+        {
+          if (Data->Cmd.Callback(UCM_EXTRACTFILE_ERR, Data->Cmd.UserData,
+              (LPARAM)CurrentFileName.c_str(), (LPARAM)Data->Cmd.DllError)==-1)
+          {
+            return ERAR_SUCCESS; // User cancelled extraction
+          }
+        }
+      }
+      
+      if (!Success)
       {
         if (Repeat)
         {
diff --git a/dll.hpp b/dll.hpp
index 04e9be1..ce4e469 100644
--- a/dll.hpp
+++ b/dll.hpp
@@ -163,7 +163,13 @@ struct RAROpenArchiveDataEx
 
 enum UNRARCALLBACK_MESSAGES {
   UCM_CHANGEVOLUME,UCM_PROCESSDATA,UCM_NEEDPASSWORD,UCM_CHANGEVOLUMEW,
-  UCM_NEEDPASSWORDW,UCM_LARGEDICT
+  UCM_NEEDPASSWORDW,UCM_LARGEDICT,
+  // Fork-only event ids: explicitly start at 100 to reserve 6..99 for any
+  // future upstream UCM_* additions. Do NOT renumber to be consecutive
+  // with UCM_LARGEDICT.
+  UCM_EXTRACTFILE = 100, // File extraction started,   P1=filename (wchar_t*), P2=file size
+  UCM_EXTRACTFILE_OK,    // File extraction succeeded, P1=filename (wchar_t*), P2=0
+  UCM_EXTRACTFILE_ERR    // File extraction failed,    P1=filename (wchar_t*), P2=error code
 };
 
 typedef int (PASCAL *CHANGEVOLPROC)(char *ArcName,int Mode);
-- 
